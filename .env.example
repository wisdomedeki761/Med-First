# =============================================================================
# GEMINI API — Google AI Studio (Primary)
# Get key: https://aistudio.google.com/app/apikey
# =============================================================================
GEMINI_API_KEY=
GEMINI_MODEL=models/gemma-4-31b-it

# Available Gemma 4 models for Gemini:
# - models/gemma-4-31b-it (Best for reasoning)
# - models/gemma-4-26b-a4b-it (Best for speed/agents)
# - models/gemma-4-8b-it (Lightweight)

# =============================================================================
# OPENROUTER API — Fallback (Multiple keys for fallback)
# Get keys: https://openrouter.ai/keys
# =============================================================================
OPENROUTER_API_KEY=

# Models in order of preference (tried sequentially if rate-limited)
OPENROUTER_MODELS=google/gemma-4-31b-it:free, google/gemma-4-26b-a4b-it:free
# use this for testing with free tier only: OPENROUTER_MODELS=openrouter/free
# OPENROUTER_MODELS=openrouter/free

# =============================================================================
# OPTIONAL: ElevenLabs for higher quality TTS
# Get key: https://elevenlabs.io/api
# Leave blank to use browser Web Speech Synthesis (free)
# =============================================================================
ELEVENLABS_API_KEY=

# =============================================================================
# APP CONFIG
# =============================================================================
NEXT_PUBLIC_APP_NAME=MediFirst
NEXT_PUBLIC_APP_URL=http://localhost:3000